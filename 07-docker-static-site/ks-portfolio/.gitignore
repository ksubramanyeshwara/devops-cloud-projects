# .gitignore - Files to exclude from Git version control

# ============================================
# Environment Variables
# ============================================
# Never commit actual environment files with secrets
.env

# ============================================
# Docker-related
# ============================================
# Docker volumes data (if using volumes locally)
data/
volumes/

# ============================================
# Operating System Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ============================================
# IDE and Editors
# ============================================
# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (IntelliJ, PyCharm, WebStorm)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# Logs and Temporary Files
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.tmp
.cache/